{
  "name": "mrashidi.me",
  "version": "0.1.149",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "generate-assets": "sh -c 'pnpm generate-sitemap & _s=$!; pnpm generate-og-images & _o=$!; _e=0; wait $_s || _e=1; wait $_o || _e=1; exit $_e'",
    "build": "NEXT_TELEMETRY_DISABLED=1 pnpm generate-assets && next build",
    "build:fast": "SKIP_PWA=true next build",
    "build:ci": "pnpm build:fast",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "generate-sitemap": "NODE_NO_WARNINGS=1 tsx scripts/generate-sitemap.ts",
    "generate-og-images": "tsx scripts/generate-og-images.jsx",
    "analyze": "ANALYZE=true next build",
    "release": "npx standard-version",
    "clean": "pnpm store prune && rm -rf node_modules .next",
    "reinstall": "pnpm clean && pnpm install"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1073.0",
    "@fontsource/albert-sans": "^5.2.8",
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/nextjs": "^10.59.0",
    "@uidotdev/usehooks": "^2.4.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "fast-xml-parser": "^5.9.3",
    "file-type": "^22.0.1",
    "framer-motion": "^12.40.0",
    "html-to-text": "^10.0.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-pwa": "^5.6.0",
    "pino": "^10.3.1",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.6.0",
    "sanitize-filename": "^1.6.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitest/ui": "^4.1.8",
    "axe-core": "^4.12.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": ">=8.5.10",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx,css,json}": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
  }
}
