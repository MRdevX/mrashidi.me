{
  "name": "mrashidi.me",
  "version": "0.1.123",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NEXT_TELEMETRY_DISABLED=1 pnpm generate-sitemap && pnpm generate-og-images && next build",
    "build:fast": "SKIP_PWA=true next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "generate-sitemap": "NODE_NO_WARNINGS=1 tsx scripts/generate-sitemap.ts",
    "generate-og-images": "tsx scripts/generate-og-images.jsx",
    "analyze": "ANALYZE=true next build",
    "release": "npx standard-version",
    "clean": "pnpm store prune && rm -rf node_modules .next",
    "reinstall": "pnpm clean && pnpm install"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1045.0",
    "@fontsource/albert-sans": "^5.2.8",
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/nextjs": "^10.52.0",
    "@uidotdev/usehooks": "^2.4.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.7.3",
    "file-type": "^22.0.1",
    "framer-motion": "^12.38.0",
    "html-react-parser": "^6.1.0",
    "html-to-text": "^10.0.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "next-pwa": "^5.6.0",
    "pino": "^10.3.1",
    "pretty-bytes": "^7.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-email": "^6.1.1",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "sanitize-filename": "^1.6.4",
    "sanitize-html": "^2.17.3",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "2.4.14",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/html-to-text": "^9.0.4",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "axe-core": "^4.11.4",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx,css,json}": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
  }
}
