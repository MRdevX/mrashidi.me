{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [120],
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 120,
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,

  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.quoteStyle": "double",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.suggest.autoImports": true,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "css.validate": false,
  "scss.validate": false,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/.pnpm-store": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/coverage": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/build": true,
    "**/out": true,
    "**/*.tsbuildinfo": true,
    "**/sw.js": true,
    "**/sw.js.map": true,
    "**/workbox-*.js": true,
    "**/workbox-*.js.map": true,
    "**/sitemap.xml": true,
    "**/.env.sentry-build-plugin": true,
    "**/public/cv": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.pnpm-store": true,
    "**/test-results": true,
    "**/playwright-report": true,
    "**/coverage": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/build": true,
    "**/out": true,
    "**/*.tsbuildinfo": true,
    "**/sw.js": true,
    "**/sw.js.map": true,
    "**/workbox-*.js": true,
    "**/workbox-*.js.map": true,
    "**/sitemap.xml": true,
    "**/.env.sentry-build-plugin": true,
    "**/public/cv": true,
    "**/pnpm-lock.yaml": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/.pnpm-store/**": true,
    "**/test-results/**": true,
    "**/playwright-report/**": true,
    "**/coverage/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/out/**": true
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "npm.packageManager": "pnpm",
  "git.autofetch": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.test.ts, ${capture}.spec.ts, ${capture}.d.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.spec.tsx, ${capture}.stories.tsx",
    "package.json": "package-lock.json, pnpm-lock.yaml, .npmrc, .pnpmrc, pnpm-workspace.yaml, .nvmrc",
    "next.config.*": "next-env.d.ts, postcss.config.*, tailwind.config.*",
    "tsconfig.json": "tsconfig.*.json, tsconfig.tsbuildinfo, next-env.d.ts",
    ".env": ".env.*, .env.example, .env.local, .env.sentry-build-plugin",
    "README.md": "CHANGELOG.md, CONTRIBUTING.md, AGENTS.md, LICENSE"
  }
}
